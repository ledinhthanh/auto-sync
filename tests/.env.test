NODE_ENV=test
DATABASE_URL="postgresql://datasync_user:datasync_password@localhost:5443/datasync_db_test?schema=public"
REDIS_URL="redis://localhost:6389"
ENCRYPTION_KEY="b1b2b3b4b5b6b7b8b1b2b3b4b5b6b7b8b1b2b3b4b5b6b7b8b1b2b3b4b5b6b7b8"

# Test Source DB
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5444
SOURCE_DB_USER=source_user
SOURCE_DB_PASS=source_password
SOURCE_DB_NAME=source_db_test

# Test Dest DB
DEST_DB_HOST=localhost
DEST_DB_PORT=5445
DEST_DB_USER=dest_user
DEST_DB_PASS=dest_password
DEST_DB_NAME=dest_db_test

# Docker Binaries (for test environment without host pg_dump)
PG_DUMP_BIN="docker exec -i -e PGPASSWORD autosync-db_source_test-1 pg_dump"
PG_RESTORE_BIN="docker exec -i -e PGPASSWORD autosync-db_dest_test-1 pg_restore"
PSQL_BIN="docker exec -i -e PGPASSWORD autosync-db_source_test-1 psql"

# Port overrides for Docker tools (inside container)
PG_DUMP_HOST=localhost
PG_DUMP_PORT=5432
PG_RESTORE_HOST=localhost
PG_RESTORE_PORT=5432
